# for bash-completion  
[[ -r "/opt/homebrew/etc/profile.d/bash_completion.sh" ]] && . "/opt/homebrew/etc/profile.d/bash_completion.sh"

# default ruby
ruby_install_root="${RUBIES_INSTALL_ROOT:-$HOME/.rubies}"
if command -v chruby >/dev/null 2>&1; then
  if [[ -d "$ruby_install_root/4.0.1" || -d "$ruby_install_root/ruby-4.0.1" ]]; then
    chruby 4.0.1
  fi
fi
