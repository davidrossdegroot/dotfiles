# Resolve Homebrew prefix for both Apple Silicon (/opt/homebrew) and Intel (/usr/local).
if command -v brew >/dev/null 2>&1; then
  HOMEBREW_PREFIX="$(brew --prefix)"
elif [[ -d /opt/homebrew ]]; then
  HOMEBREW_PREFIX="/opt/homebrew"
else
  HOMEBREW_PREFIX="/usr/local"
fi

# my bin directory
export PATH="$HOME/bin:$PATH"
# vs code
export PATH="/Applications/Visual Studio Code.app/Contents/Resources/app/bin:$PATH"
export PATH="$HOMEBREW_PREFIX/bin:$PATH"

# nvm
export NVM_DIR="$HOME/.nvm"
if [[ -s "$HOMEBREW_PREFIX/opt/nvm/nvm.sh" ]]; then
  if [[ -e "$NVM_DIR" && ! -d "$NVM_DIR" ]]; then
    echo "nvm: NVM_DIR '$NVM_DIR' exists but is not a directory; skipping initialization." >&2
  else
    [[ -d "$NVM_DIR" ]] || mkdir -p "$NVM_DIR"
    \. "$HOMEBREW_PREFIX/opt/nvm/nvm.sh"
  fi
fi

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d "$PYENV_ROOT/bin" ]] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv >/dev/null 2>&1; then
  eval "$(pyenv init - zsh)"
fi

# libpq for psql (if installed with Homebrew)
[[ -d "$HOMEBREW_PREFIX/opt/libpq/bin" ]] && export PATH="$HOMEBREW_PREFIX/opt/libpq/bin:$PATH"

# chruby (if installed with Homebrew)
[ -r "$HOMEBREW_PREFIX/opt/chruby/share/chruby/chruby.sh" ] && source "$HOMEBREW_PREFIX/opt/chruby/share/chruby/chruby.sh"
[ -r "$HOMEBREW_PREFIX/opt/chruby/share/chruby/auto.sh" ] && source "$HOMEBREW_PREFIX/opt/chruby/share/chruby/auto.sh"

export PATH="$HOME/.local/bin:$PATH"
